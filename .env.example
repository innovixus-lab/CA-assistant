# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── App URL ──────────────────────────────────────────────────────────────────
# The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for OAuth callbacks and webhook URLs.
APP_URL="MY_APP_URL"

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
# The Twilio WhatsApp sandbox or approved number (include "whatsapp:" prefix)
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# ─── Razorpay (UPI Payment Gateway) ─────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_...) during development
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
# Set in Razorpay Dashboard → Settings → Webhooks (used to verify webhook events)
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
# CA's WhatsApp number to receive payment notifications
CA_WHATSAPP_NUMBER="+919876543210"

# ─── Email — SMTP (outbound) ──────────────────────────────────────────────────
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your_app_password"

# ─── Email — IMAP (inbound polling) ──────────────────────────────────────────
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER="your@gmail.com"
IMAP_PASS="your_app_password"
# How often to poll for new emails (milliseconds, default 60000 = 1 minute)
EMAIL_POLL_INTERVAL_MS="60000"
